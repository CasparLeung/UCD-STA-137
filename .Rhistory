library(ggplot2)
# Read the file skipping the first 2 rows
df <- read.csv("multiTimeline.csv", skip = 2, header = TRUE)
# Rename columns
colnames(df) <- c("Time", "Interest")
#df$Time <- as.POSIXct(df$Time, format="%Y-%m-%dT%H:%M:%S%z")
# Check the first few rows
head(df)
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "lightgray") +        # Raw data line
geom_smooth(color = "blue", se = FALSE) + # The trend line
theme_minimal() +
labs(title = "BTS Search Interest Trend",
x = "Time",
y = "Interest Score")
