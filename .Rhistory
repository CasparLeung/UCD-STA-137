library(ggplot2)
# Read the file skipping the first 2 rows
df <- read.csv("multiTimeline.csv", skip = 2, header = TRUE)
# Rename columns
colnames(df) <- c("Time", "Interest")
df$Time <- substr(df$Time, 1, 19)
df$Time <- as.POSIXct(df$Time, format="%Y-%m-%dT%H:%M:%S")
# Check the first few rows
head(df)
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%H:%M", date_breaks = "4 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%Y:%d", date_breaks = "4 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%Y-%m-%d", date_breaks = "4 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%Y-%m-%d", date_breaks = "1 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%Y-%m-%d", date_breaks = "24 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%Y-%m-%d", date_breaks = "12 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%Y-%m-%d %H:%M", date_breaks = "12 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Time, y = Interest)) +
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "steelblue", linewidth = 1) +
# Add the text labels
# vjust = -1 pushes the text slightly above the point
geom_text(data = points_to_label,
aes(label = LabelName),
vjust = -1,
color = "darkred",
fontface = "bold") +
# Optional: Add dots at those 3 points so the labels have a "target"
geom_point(data = points_to_label, color = "darkred", size = 2) +
# Formatting
theme_minimal() +
scale_x_datetime(date_labels = "%m-%d %H:%M", date_breaks = "12 hours") +
labs(title = "BTS Search Interest with Key Point Labels")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "steelblue", linewidth = 1) +
# Add the text labels
# vjust = -1 pushes the text slightly above the point
geom_text(data = points_to_label,
aes(label = LabelName),
vjust = -1,
color = "darkred",
fontface = "bold") +
# Optional: Add dots at those 3 points so the labels have a "target"
geom_point(data = points_to_label, color = "darkred", size = 2) +
# Formatting
theme_minimal() +
scale_x_datetime(date_labels = "%m-%d %H:%M", date_breaks = "12 hours") +
labs(title = "BTS Search Interest with Key Point Labels")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%Y-%m-%d %H:%M", date_breaks = "4 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "blue") +
theme_minimal() +
# Force the X-axis to show Hours and Minutes
scale_x_datetime(date_labels = "%Y-%m-%d %H:%M", date_breaks = "6 hours") +
labs(title = "BTS Interest Trend (Hours Included)")
ggplot(df, aes(x = Interest)) +
# bins = 10 or 15 is usually best for this type of data
geom_histogram(bins = 15, fill = "steelblue", color = "white") +
theme_minimal() +
labs(
title = "Distribution of BTS Search Interest",
subtitle = "Frequency of interest scores across the recorded period",
x = "Interest Score (0-100)",
y = "Number of 8-minute Intervals"
)
#Interest vs time plot
ggplot(df, aes(x = Time, y = Interest)) +
# This adds the line connecting the points
geom_line(color = "blue", alpha = 0.5) +
# This ADDS all the individual data points (dots)
geom_point(color = "blue", size = 1) +
theme_minimal() +
# Changed labels to %H:%M so you can see the 'Period of Time' for the points
scale_x_datetime(date_labels = "%m-%d %H:%M", date_breaks = "6 hours") +
labs(title = "BTS Interest Trend: Individual Data Points")
#Interest vs time plot
ggplot(df, aes(x = Time, y = Interest)) +
# Layer 1: Individual Data Points (The "Raw" dots)
geom_point(color = "gray70", size = 1) +
# Layer 2: Connecting Line (Lightly showing the sequence)
geom_line(color = "gray80", alpha = 0.5) +
# Layer 3: The Trend Line (LOESS smoothing)
# se = FALSE removes the gray shadow around the line
geom_smooth(color = "red", method = "loess", span = 0.2, se = FALSE, linewidth = 1.2) +
theme_minimal() +
# Show Hour:Minute and Date every 6 hours
scale_x_datetime(date_labels = "%m-%d %H:%M", date_breaks = "6 hours") +
labs(
title = "BTS Interest: Data Points & Trend Line",
subtitle = "Gray dots show 8-minute data; Red line shows the overall trend",
x = "Time Period",
y = "Interest Score"
)
#Interest vs time plot
ggplot(df, aes(x = Time, y = Interest)) +
# This adds the line connecting the points
geom_line(color = "blue", alpha = 0.5) +
# This ADDS all the individual data points (dots)
geom_point(color = "blue", size = 1) +
theme_minimal() +
# Changed labels to %H:%M so you can see the 'Period of Time' for the points
scale_x_datetime(date_labels = "%m-%d %H:%M", date_breaks = "6 hours") +
labs(title = "BTS Interest Trend: Individual Data Points")
#Interest vs time plot
ggplot(df, aes(x = Time, y = Interest)) +
# A. The raw connecting line (thin and light)
geom_line(color = "gray60", linewidth = 0.5) +
# B. All individual data points (8-minute intervals)
geom_point(color = "steelblue", size = 1, alpha = 0.7) +
# C. The Trend Line (smooths out the noise)
geom_smooth(method = "loess", color = "darkred", se = FALSE, linewidth = 1) +
# Formatting
theme_minimal() +
scale_x_datetime(
date_labels = "%m-%d %H:%M",
date_breaks = "6 hours"
) +
labs(
title = "BTS Interest: Points, Raw Line, and Trend",
x = "Time of Day",
y = "Interest Score"
)
library(ggplot2)
# Read the file skipping the first 2 rows
df <- read.csv("multiTimeline.csv", skip = 2, header = TRUE)
# Rename columns
colnames(df) <- c("Time", "Interest")
df$Time <- substr(df$Time, 1, 19)
df$Time <- as.POSIXct(df$Time, format="%Y-%m-%dT%H:%M:%S")
# Check the first few rows
head(df)
#Interest vs time plot
ggplot(df, aes(x = Time, y = Interest)) +
geom_line(color = "gray60", linewidth = 0.5) +
geom_point(color = "steelblue", size = 1, alpha = 0.7) +
geom_smooth(method = "loess", color = "darkred", se = FALSE, linewidth = 1) +
theme_minimal() +
scale_x_datetime(
date_labels = "%m-%d %H:%M",
date_breaks = "6 hours"
) +
labs(
title = "BTS Interest: Points, Raw Line, and Trend",
x = "Time of Day",
y = "Interest Score"
)
#histogram distribution of search interest
ggplot(df, aes(x = Interest)) +
# bins = 10 or 15 is usually best for this type of data
geom_histogram(bins = 15, fill = "steelblue", color = "white") +
theme_minimal() +
labs(
title = "Distribution of BTS Search Interest",
subtitle = "Frequency of interest scores across the recorded period",
x = "Interest Score (0-100)",
y = "Frequency"
)
#ACF PACF plot
par(mfrow=c(1,2)) # Put them side-by-side
acf(df$Interest, main="ACF (Memory)")
pacf(df$Interest, main="PACF (Immediate Correlation)")
par(mfrow=c(1,1)) # Reset layout
# box plot
ggplot(df, aes(x = Hour, y = Interest, fill = Hour)) +
geom_boxplot(show.legend = FALSE) +
theme_minimal() +
labs(title = "Plot 3: Search Interest Distribution by Hour")
